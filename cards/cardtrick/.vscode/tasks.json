{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "sjasmplus",
            "type": "shell",
            "command": "${workspaceFolder}/../../tools/sjasmplus",
            "args": [
                "--lst=../obj/cardtrick.list",
                "--lstlab",
                "--sym=../obj/cardtrick.labels",
                "--raw=../obj/cardtrick.bin",
                "--fullpath",
				"--zxnext=cspect",
                // "--msg=war"
                "src/main.asm"
            ],
            "problemMatcher": {
                "fileLocation": [
                    "relative",
                    "${workspaceRoot}"
                ],
                "pattern": {
                    "regexp": "^(.*)\\((\\d+)\\):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "message": 4
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
