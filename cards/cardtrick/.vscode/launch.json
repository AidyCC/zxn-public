    // Weitere Informationen finden Sie unter https://go.microsoft.com/fwlink/?linkid=830387
   
    {
        "version": "0.2.0",
        "configurations": [
            {
                "type": "dezog",
                "request": "launch",
                "name": "Z80 Debugger",                
                "remoteType": "cspect",      
  // connect to the CSpect emulator via TCIP          
                "cspect": 
                {
                        "hostname": "localhost",
                        "port": 11000
                },
  // for when my next arrives i hope this works
                "zxnext": 
                {
                        "baudrate": 230400,
                        "port": "/dev/tty.usbserial"
                },
                "rootFolder": "${fileDirname}",
                "listFiles": [
                  {
                      "path": "../obj/cardtrick.lst",
                      "useFiles": true,
                      "asm": "../../../tools/sjasmplus",
                      "mainFile": "../src/main.asm"
                  }
                ],
                "disassemblerArgs": {
                    "esxdosRst": true
                },
                "load": "../bin/cardtrick.nex",
                "skipInterrupt": false,
                "startAutomatically": false
            }
        ]
    }
