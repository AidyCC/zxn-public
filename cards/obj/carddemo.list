  21+ 8000              ; coverts a 1bpp byte into 4bpp format suitable for Tilemap
  22+ 8000
  23+ 8000              TM_TRANSPARENT_CLR	EQU	%00000000
  24+ 8000              TM_BLACK_CLR		EQU %00000100
  25+ 8000              TM_WHITE_CLR		EQU %00001111
  26+ 8000              TM_BLUE_CLR			EQU %00000010
  27+ 8000              TM_RED_CLR			EQU %00000001
  28+ 8000
