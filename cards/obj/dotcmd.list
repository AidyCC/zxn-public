  28+ 2500              	MACRO CONVERT_BYTE b, bgclr, fgclr
  29+ 2500 ~            m=%10000000
  30+ 2500 ~            		WHILE m > 0
  31+ 2500 ~            r=0
  32+ 2500 ~            			IF b & m
  33+ 2500 ~            r =r| fgclr<< 4
  34+ 2500 ~            			ELSE
  35+ 2500 ~            r=r|bgclr << 4
