  21+ 2400              ; coverts a 1bpp byte into 4bpp format suitable for Tilemap
  22+ 2400
  23+ 2400              TM_TRANSPARENT_CLR	EQU	%00000000
  24+ 2400              TM_BLACK_CLR		EQU %00000100
  25+ 2400              TM_WHITE_CLR		EQU %00001111
  26+ 2400              TM_BLUE_CLR			EQU %00000010
  27+ 2400              TM_RED_CLR			EQU %00000001
  28+ 2400
  29+ 2400              TILEMAP_DEFS_START			equ	0x4000
  30+ 2400              TILEMAP_START				equ	((TILEMAP_DEFS_START+0x4000) - (40 * 2 * 32))
  31+ 2400
  32+ 2400              	MACRO CONVERT_BYTE b, bgclr, fgclr
  33+ 2400 ~            m = %10000000
  34+ 2400 ~            		WHILE m > 0
  35+ 2400 ~            r = 0
  36+ 2400 ~            			IF b & m
  37+ 2400 ~            r = r | (fgclr << 4)
  38+ 2400 ~            			ELSE
  39+ 2400 ~            r = r | (bgclr << 4)
  40+ 2400 ~            			ENDIF
  41+ 2400 ~            m = m >> 1
  42+ 2400 ~            			IF b & m
  43+ 2400 ~            r = r | fgclr
  44+ 2400 ~            			ELSE
  45+ 2400 ~            r = r | bgclr
  46+ 2400 ~            			ENDIF
  47+ 2400 ~            m = m >> 1
  48+ 2400 ~            			DEFB	r
  49+ 2400 ~            		ENDW
  50+ 2400              	ENDM
  51+ 2400
