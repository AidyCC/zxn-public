  40+ 2500 ~            			ELSE
  41+ 2500 ~            r=r|bclr
  42+ 2500 ~            			END IF
  43+ 2500 ~            m=m >> 1
  44+ 2500 ~            			TILE_DATA r
  45+ 2500 ~            		ENDW
