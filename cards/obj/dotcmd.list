   1+ 20BE              ; ***************************************************************************
   2+ 20BE              ; * Argument handling for dot commands                                      *
   3+ 20BE              ; ***************************************************************************
   4+ 20BE              ; In order to include this file in dot command sources, a "show_usage"
   5+ 20BE              ; routine must be present.
   6+ 20BE              ;
   7+ 20BE              ; This routine will parse quoted or unquoted arguments from the command tail.
   8+ 20BE              ; Within a quoted argument, \ can be used to escape a quote.
   9+ 20BE
  10+ 20BE              ; Define the variable ARG_PARAMS_DEHL before including:
  11+ 20BE              ; ARG_PARAMS_DEHL       equ     1       ; on entry: HL=tail address
  12+ 20BE                                                      ;           DE=argument dest
  13+ 20BE              ; ARG_PARAMS_DEHL       equ     0       ; on entry: (command_tail)=tail addr
  14+ 20BE                                                      ;           argument stored at temparg
  15+ 20BE
  16+ 20BE
  17+ 20BE              ; ***************************************************************************
  18+ 20BE              ; * Parse an argument from the command tail                                 *
  19+ 20BE              ; ***************************************************************************
  20+ 20BE              ; Entry: HL or (command_tail)=remaining command tail
  21+ 20BE              ;        argument is parsed to memory at DE or temparg
  22+ 20BE              ; Exit:  Fc=0 if no argument
  23+ 20BE              ;        Fc=1: parsed argument has been copied and null-terminated
  24+ 20BE              ;              command tail address is updated to after this argument
  25+ 20BE              ;        BC=length of argument
  26+ 20BE              ; NOTE: BC is validated to be 1..255; if not, it does not return but instead
  27+ 20BE              ;       exits via show_usage.
  28+ 20BE
  29+ 20BE              get_sizedarg:
  30+ 20BE                      IFNDEF  ARG_PARAMS_DEHL
  31+ 20BE ~                            ld      hl,(command_tail)
  32+ 20BE ~                            ld      de,temparg
  33+ 20BE                      ENDIF ; !ARG_PARAMS_DEHL
  34+ 20BE 01 00 00             ld      bc,0                    ; initialise size to zero
  35+ 20C1              get_sizedarg_loop:
  36+ 20C1 7E                   ld      a,(hl)
  37+ 20C2 23                   inc     hl
  38+ 20C3 A7                   and     a
  39+ 20C4 C8                   ret     z                       ; exit with Fc=0 if $00
  40+ 20C5 FE 0D                cp      $0d
  41+ 20C7 C8                   ret     z                       ; or if CR
  42+ 20C8 FE 3A                cp      ':'
  43+ 20CA C8                   ret     z                       ; or if ':'
  44+ 20CB FE 20                cp      ' '
  45+ 20CD 28 F2                jr      z,get_sizedarg_loop     ; skip any spaces
  46+ 20CF FE 22                cp      '"'
  47+ 20D1 28 26                jr      z,get_sizedarg_quoted   ; on for a quoted arg
  48+ 20D3              get_sizedarg_unquoted:
  49+ 20D3 12                   ld      (de),a                  ; store next char into dest
  50+ 20D4 13                   inc     de
  51+ 20D5 0C                   inc     c                       ; increment length
  52+ 20D6 28 35                jr      z,get_sizedarg_badsize  ; don't allow >255
  53+ 20D8 7E                   ld      a,(hl)
  54+ 20D9 A7                   and     a
  55+ 20DA 28 15                jr      z,get_sizedarg_complete ; finished if found $00
  56+ 20DC FE 0D                cp      $0d
  57+ 20DE 28 11                jr      z,get_sizedarg_complete ; or CR
  58+ 20E0 FE 3A                cp      ':'
  59+ 20E2 28 0D                jr      z,get_sizedarg_complete ; or ':'
  60+ 20E4 FE 22                cp      '"'
  61+ 20E6 28 09                jr      z,get_sizedarg_complete ; or '"' indicating start of next arg
  62+ 20E8 FE 2C                cp      ','
  63+ 20EA 28 05                jr      z,get_sizedarg_complete ; or ',' indicating start of next arg
  64+ 20EC 23                   inc     hl
  65+ 20ED FE 20                cp      ' '
  66+ 20EF 20 E2                jr      nz,get_sizedarg_unquoted; continue until space
  67+ 20F1              get_sizedarg_complete:
  68+ 20F1 AF                   xor     a
  69+ 20F2 12                   ld      (de),a                  ; terminate argument with NULL
  70+ 20F3 78                   ld      a,b
  71+ 20F4 B1                   or      c
  72+ 20F5 28 16                jr      z,get_sizedarg_badsize  ; don't allow zero-length args
  73+ 20F7                      IFNDEF  ARG_PARAMS_DEHL
  74+ 20F7 ~                            ld      (command_tail),hl       ; update command tail pointer
  75+ 20F7                      ENDIF ; !ARG_PARAMS_DEHL
  76+ 20F7 37                   scf                             ; Fc=1, argument found
  77+ 20F8 C9                   ret
  78+ 20F9              get_sizedarg_quoted:
  79+ 20F9 7E                   ld      a,(hl)
