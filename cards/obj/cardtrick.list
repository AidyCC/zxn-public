 16+  8000              ; coverts a 1bpp byte into 4bpp format suitable for Tilemap
 17+  8000
 18+  8000              TM_BLACK_CLR	EQU %00000000
 19+  8000              TM_WHITE_CLR	EQU %00000001
 20+  8000              TM_BLUE_CLR		EQU %00000010
 21+  8000              TM_RED_CLR		EQU %00000011
 22+  8000
 23+  8000              	MACRO CONVERT_BYTE b, bgclr, fgclr
 24+  8000 ~            m=%10000000
 25+  8000 ~            		WHILE m > 0
 26+  8000 ~            r=0
 27+  8000 ~            			IF b & m
 28+  8000 ~            r =r| fgclr<< 4
 29+  8000 ~            			ELSE
 30+  8000 ~            r=r|bgclr << 4
 31+  8000 ~            			ENDIF
 32+  8000 ~            m=m >> 1
 33+  8000 ~            			IF b & m
 34+  8000 ~            r=r|fgclr
 35+  8000 ~            			ELSE
 36+  8000 ~            r=r|bclr
 37+  8000 ~            			END IF
 38+  8000 ~            m=m >> 1
 39+  8000 ~            			TILE_DATA r
 40+  8000 ~            		ENDW
 41+  8000              	ENDM
 42+  8000
