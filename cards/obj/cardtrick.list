 317+ 8FD6              	MACRO	INC_RAW fn, sb, n
 318+ 8FD6 ~            COUNT = n
 319+ 8FD6 ~            BNK_OFFSET = 0x00
 320+ 8FD6 ~            ADDR_OFFSET = 0x0000
 321+ 8FD6 ~            		WHILE COUNT > 0
 322+ 8FD6 ~            			MMU 6, sb + BNK_OFFSET, 0xC000
 323+ 8FD6 ~            			IF COUNT > 1
 324+ 8FD6 ~            				INCBIN fn, ADDR_OFFSET, 0x2000
 325+ 8FD6 ~            			ELSE
 326+ 8FD6 ~            				INCBIN fn, ADDR_OFFSET
 327+ 8FD6 ~            			ENDIF
 328+ 8FD6 ~            ADDR_OFFSET = ADDR_OFFSET + 0x2000
 329+ 8FD6 ~            BNK_OFFSET = BNK_OFFSET + 0x01
 330+ 8FD6 ~            COUNT = COUNT - 0x01
 331+ 8FD6 ~            		ENDW
