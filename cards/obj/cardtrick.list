  31+ 8000
  32+ 8000              	MACRO CONVERT_BYTE b, bgclr, fgclr
  33+ 8000 ~            m = %10000000
  34+ 8000 ~            		WHILE m > 0
  35+ 8000 ~            r = 0
  36+ 8000 ~            			IF b & m
  37+ 8000 ~            r = r | (fgclr << 4)
  38+ 8000 ~            			ELSE
  39+ 8000 ~            r = r | (bgclr << 4)
  40+ 8000 ~            			ENDIF
  41+ 8000 ~            m = m >> 1
  42+ 8000 ~            			IF b & m
  43+ 8000 ~            r = r | fgclr
  44+ 8000 ~            			ELSE
  45+ 8000 ~            r = r | bgclr
  46+ 8000 ~            			ENDIF
  47+ 8000 ~            m = m >> 1
  48+ 8000 ~            			DEFB	r
  49+ 8000 ~            		ENDW
  50+ 8000              	ENDM
  51+ 8000
