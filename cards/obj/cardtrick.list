  21+ 8000              ; coverts a 1bpp byte into 4bpp format suitable for Tilemap
  22+ 8000
  23+ 8000              TM_BLACK_CLR	EQU %00000000
  24+ 8000              TM_WHITE_CLR	EQU %00000001
  25+ 8000              TM_BLUE_CLR		EQU %00000010
  26+ 8000              TM_RED_CLR		EQU %00000011
  27+ 8000
  28+ 8000              	MACRO CONVERT_BYTE b, bgclr, fgclr
  29+ 8000 ~            m=%10000000
  30+ 8000 ~            		WHILE m > 0
  31+ 8000 ~            r=0
  32+ 8000 ~            			IF b & m
  33+ 8000 ~            r =r| fgclr<< 4
  34+ 8000 ~            			ELSE
  35+ 8000 ~            r=r|bgclr << 4
  36+ 8000 ~            			ENDIF
  37+ 8000 ~            m=m >> 1
  38+ 8000 ~            			IF b & m
  39+ 8000 ~            r=r|fgclr
  40+ 8000 ~            			ELSE
  41+ 8000 ~            r=r|bclr
  42+ 8000 ~            			END IF
  43+ 8000 ~            m=m >> 1
  44+ 8000 ~            			TILE_DATA r
  45+ 8000 ~            		ENDW
  46+ 8000              	ENDM
  47+ 8000
  48+ 8000              	MACRO TILE_DATA b1, b2, b3, b4, b5, b6, b7, b8, bclr, fclr
