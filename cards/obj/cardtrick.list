 315+ 8FE2              	MACRO	INC_RAW fn, sb, n
 316+ 8FE2 ~            COUNT = n
 317+ 8FE2 ~            BNK_OFFSET = 0x00
 318+ 8FE2 ~            ADDR_OFFSET = 0x0000
 319+ 8FE2 ~            		WHILE COUNT > 0
 320+ 8FE2 ~            			MMU 6, sb + BNK_OFFSET, 0xC000
 321+ 8FE2 ~            			IF COUNT > 1
 322+ 8FE2 ~            				INCBIN fn, ADDR_OFFSET, 0x2000
 323+ 8FE2 ~            			ELSE
 324+ 8FE2 ~            				INCBIN fn, ADDR_OFFSET
 325+ 8FE2 ~            			ENDIF
 326+ 8FE2 ~            ADDR_OFFSET = ADDR_OFFSET + 0x2000
 327+ 8FE2 ~            BNK_OFFSET = BNK_OFFSET + 0x01
 328+ 8FE2 ~            COUNT = COUNT - 0x01
 329+ 8FE2 ~            		ENDW
 330+ 8FE2              	ENDM
